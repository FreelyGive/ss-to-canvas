{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    /* Modules */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,

    /* Path Aliases - Vite handles runtime resolution, TS uses these for type checking */
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["./node_modules/drupal-canvas/dist/*"],
      "@/components/*": ["./src/components/*"]
    },

    /* Emit */
    "noEmit": true,

    /* Interop Constraints */
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking - relaxed for mixed JS/TS codebase */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,

    /* JavaScript Support — checkJs enables JSDoc type validation in .jsx files */
    "allowJs": true,
    "checkJs": true,

    /* Skip lib check for faster builds */
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "*.config.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "storybook-static", "src/**/dist"]
}
