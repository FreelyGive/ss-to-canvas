##
# Example configuration for Drupal Canvas CLI.
##

# The CMS / API URL used by Canvas CLI to connect to the site.
# For Acquia Source this may differ from the public-facing URL.
CANVAS_SITE_URL=https://abc12345-1234-1234-1234-123456789abc.cms.acquia.site
CANVAS_JSONAPI_PREFIX=jsonapi

# Follow this guide to set up the Canvas OAuth module for authentication:
# https://git.drupalcode.org/project/canvas/-/tree/1.x/modules/canvas_oauth#2-setup
CANVAS_CLIENT_ID=canvas-ai
CANVAS_CLIENT_SECRET=secret

# The public-facing URL of the site (may differ from CMS URL for Acquia Source).
CANVAS_PUBLIC_URL=https://example.acquia.site

# Local DDEV Drupal site — used by canvas:push:local.
# Auto-filled during fresh Drupal install; fill in manually if using an existing local site.
CANVAS_LOCAL_SITE_URL=
CANVAS_LOCAL_JSONAPI_PREFIX=jsonapi
CANVAS_LOCAL_CLIENT_ID=
CANVAS_LOCAL_CLIENT_SECRET=

# Need to troubleshoot something? Set the following to true.
#CANVAS_VERBOSE=false

# Only set if the default scopes from the `canvas_oauth` module are not used.
#CANVAS_SCOPE="canvas:js_component canvas:asset_library"

# Set to true if the content API does not require authentication.
#CONTENT_NO_AUTH=false

# OAuth scope for content API operations.
#CONTENT_OAUTH_SCOPE=canvas:js_component canvas:asset_library member

# Anthropic API key — only needed by the website-to-components migration pipeline
# if running without an active Claude Code session (e.g. CI). In normal use,
# run `ddev claude` once to authenticate and the pipeline will use those credentials.
#ANTHROPIC_API_KEY=
